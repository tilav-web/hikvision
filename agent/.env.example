# ─── Cloud server (qayerda NestJS app ishlayapti) ───
SERVER_URL=https://api.your-app.com

# ─── Kampaniya tokeni ───
# Super-admin admin paneldan Companies → Token nusxalash tugmasi orqali oladi
# va shu joyga joylanadi. Bitta kampaniya = bitta token.
# Bir mijozda bir nechta agent bo'lishi mumkin — barchasi shu token bilan ulanadi.
COMPANY_TOKEN=

# ─── Agent nomi ───
# Har kampaniya ichida unikal bo'lishi kerak (masalan: "Bosh ofis - RPI4").
# Server bu nomda agent yo'q bo'lsa avtomatik yaratadi va admin panelda ko'rinadi.
AGENT_NAME=

# ─── Ixtiyoriy ───
LOG_LEVEL=info
RECONNECT_DELAY_MS=5000
CMD_TIMEOUT_MS=60000

# Qurilma soatini (syncTime) sozlashda ishlatiladigan timezone.
# Bo'sh qoldirilsa Asia/Tashkent (UTC+5) ishlatiladi.
DEVICE_TZ=Asia/Tashkent
