# ─── Cloud server (qayerda NestJS app ishlayapti) ───
SERVER_URL=https://api.your-app.com

# Server tomonidan agentga beriladigan unikal token
# Bu token bir agentni identifikatsiya qiladi va u agent boshqaradigan
# barcha qurilmalar serverda ushbu agent_id ga bog'langan bo'ladi.
AGENT_TOKEN=

# ─── Ixtiyoriy ───
LOG_LEVEL=info
RECONNECT_DELAY_MS=5000
CMD_TIMEOUT_MS=60000

# Eslatma: qurilma (host/port/username/password) ma'lumotlari
# server tomonidan welcome event'da yuboriladi. Bu agent endi bir nechta
# qurilmani boshqara oladi — ularning ro'yxatini server kontrol qiladi.
