# Server
PORT=3000
NODE_ENV=development
# CORS — vergul bilan ajratilgan aniq domenlar. Prod'da '*' ISHLATMANG
# (har qanday sayt'ni credential bilan aks ettiradi). Masalan:
# CORS_ORIGIN=https://panel.example.com,https://admin.example.com
CORS_ORIGIN=http://localhost:5173

# Attendance/kunlik chegara timezone'i (kunni qachon yopish, kechikish hisobi)
TZ_DEFAULT=Asia/Tashkent

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=hikvision
# Always false in production — use migrations
DB_SYNC=false

# Redis — BullMQ (fon-vazifalar), throttler storage, socket.io adapter uchun.
# docker-compose ichida host avtomatik 'redis' bo'ladi.
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_long_random_string
JWT_EXPIRES_IN=7d

# Bootstrap super-admin (created on startup if missing)
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=ChangeMe123!
SUPER_ADMIN_NAME=Super Admin

# Encryption key for storing device passwords (32 bytes hex = 64 chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_with_64_char_hex_string_replace_with_64_char_hex_string12

# Public base URL of THIS server (aparat shu URL ga event yuboradi)
# Example: http://192.168.1.100:3000  yoki  https://api.example.com
PUBLIC_BASE_URL=http://192.168.1.100:3000

# Default ISAPI request timeout (ms)
ISAPI_TIMEOUT_MS=15000

# Telegram bot (ixtiyoriy — bo'sh bo'lsa bildirishnomalar o'chiq)
TELEGRAM_BOT_TOKEN=
